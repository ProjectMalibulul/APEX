{
  "name": "apex-vscode-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "cd .. && npm run build",
    "test": "cd .. && npm run test:vscode",
    "smoke": "cd .. && npm run smoke:vscode"
  },
  "activationEvents": ["onCommand:apex.renderClassDiagram"],
  "contributes": {
    "commands": [
      {
        "command": "apex.renderClassDiagram",
        "title": "Apex: Render Class Diagram"
      }
    ]
  }
}
